# Server
PORT=4000
SESSION_SECRET=change-me-before-deploy

# Database
DATABASE_URL=postgres://localhost:5432/transcend
# Used by npm test so a force-sync never touches the dev DB
DATABASE_TEST_URL=postgres://localhost:5432/transcend_test

# Google OAuth (optional — email/password login works without these)
CLIENT_ID=your-google-client-id
CLIENT_SECRET=your-google-client-secret

# socket.io CORS origin (production only)
# Set to your deployed app URL to restrict WebSocket upgrades to that origin.
# Leave unset in dev — the server defaults to '*' when NODE_ENV != production.
# APP_ORIGIN=https://your-app.example.com

# WebRTC ICE servers (served to clients via GET /api/ice-servers)
# STUN_URL defaults to the public Google STUN server if unset.
# TURN_* are optional — omit them if you have no TURN relay.
# Consider coturn (https://github.com/coturn/coturn) for a self-hosted option.
# STUN_URL=stun:stun.l.google.com:19302
# TURN_URL=turn:your-turn-server.example.com:3478
# TURN_USERNAME=your-turn-username
# TURN_CREDENTIAL=your-turn-credential
