{
  "name": "transcend",
  "version": "1.0.0",
  "description": "A social and educational VR environment.",
  "main": "server/index.js",
  "scripts": {
    "build": "webpack",
    "build-watch": "webpack -w",
    "seed": "node db/seed.js",
    "server": "node --watch server/index.js",
    "start": "webpack && node --watch server/index.js",
    "test": "cross-env NODE_ENV=testing mocha --require @babel/register browser/**/*.test.js browser/**/*.test.jsx db/**/*.test.js server/**/*.test.js",
    "test-watch": "cross-env NODE_ENV=testing mocha --require @babel/register --watch browser/**/*.test.js browser/**/*.test.jsx db/**/*.test.js server/**/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TranscendVR/transcend.git"
  },
  "keywords": [
    "social",
    "vr"
  ],
  "author": "Joey Darbyshire, Sean McBride, Yoo-Nah Park, Beth Qiang",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/TranscendVR/transcend/issues"
  },
  "homepage": "https://github.com/TranscendVR/transcend#readme",
  "dependencies": {
    "aframe": "^1.7.0",
    "aframe-gif-shader": "0.9.1",
    "@babel/core": "^7.0.0",
    "@babel/plugin-proposal-class-properties": "^7.0.0",
    "@babel/plugin-proposal-decorators": "^7.0.0",
    "@babel/preset-env": "^7.0.0",
    "@babel/preset-react": "^7.0.0",
    "babel-loader": "^8.0.0",
    "bcryptjs": "^3.0.0",
    "chalk": "^4.0.0",
    "cookie-session": "^2.0.0-alpha.2",
    "cross-env": "^3.1.4",
    "express": "^5.0.0",
    "font-awesome": "^4.7.0",
    "immutable": "^4.0.0",
    "@mui/material": "^5.0.0",
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth": "^2.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.0.0",
    "redux": "^4.2.1",
    "redux-thunk": "^3.1.0",
    "sequelize": "^6.0.0",
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.7.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  },
  "devDependencies": {
    "@babel/register": "^7.0.0",
    "babel-eslint": "^10.1.0",
    "chai": "^3.5.0",
    "chai-immutable": "^1.6.0",
    "esl": "^5.2.2",
    "eslint": "^3.14.0",
    "eslint-config-standard": "^6.2.1",
    "eslint-plugin-promise": "^3.4.0",
    "eslint-plugin-react": "^6.9.0",
    "eslint-plugin-standard": "^2.0.1",
    "mocha": "^3.2.0",
    "morgan": "^1.7.0"
  }
}
