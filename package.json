{
  "name": "transcend",
  "version": "1.0.0",
  "description": "A social and educational VR environment.",
  "main": "server/index.js",
  "scripts": {
    "build": "node build.mjs",
    "build-watch": "node build.mjs --watch",
    "build-prod": "cross-env NODE_ENV=production node build.mjs",
    "seed": "node db/seed.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "server": "node --watch server/index.js",
    "start": "node build.mjs && node --watch server/index.js",
    "test": "vitest run",
    "test-watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TranscendVR/transcend.git"
  },
  "keywords": [
    "social",
    "vr"
  ],
  "author": "Joey Darbyshire, Sean McBride, Yoo-Nah Park, Beth Qiang",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/TranscendVR/transcend/issues"
  },
  "homepage": "https://github.com/TranscendVR/transcend#readme",
  "dependencies": {
    "aframe": "^1.7.0",
    "aframe-gif-shader": "0.9.1",
    "bcryptjs": "^3.0.0",
    "cookie-session": "^2.0.0-alpha.2",
    "cross-env": "^3.1.4",
    "express": "^5.0.0",
    "font-awesome": "^4.7.0",
    "immutable": "^4.0.0",
    "@mui/material": "^5.0.0",
    "@emotion/react": "^11.0.0",
    "@emotion/styled": "^11.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth": "^2.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.0.0",
    "redux": "^4.2.1",
    "redux-thunk": "^3.1.0",
    "sequelize": "^6.0.0",
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.7.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.0.0",
    "globals": "^15.0.0",
    "neostandard": "^0.12.0",
    "morgan": "^1.7.0",
    "vitest": "^3.0.0"
  }
}
