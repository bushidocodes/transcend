# Server
PORT=4000
# REQUIRED in production — signs the session cookie. The server refuses to boot in
# production if this is unset (in dev it falls back to an insecure key with a warning).
# Generate a strong value with: openssl rand -hex 32
SESSION_SECRET=change-me-before-deploy

# Database
DATABASE_URL=postgres://localhost:5432/transcend
# Used by npm test so a force-sync never touches the dev DB
DATABASE_TEST_URL=postgres://localhost:5432/transcend_test

# Google OAuth (optional — email/password login works without these)
CLIENT_ID=your-google-client-id
CLIENT_SECRET=your-google-client-secret

# socket.io CORS origin (production only)
# Set to your deployed app URL to restrict WebSocket upgrades to that origin.
# Leave unset in dev — the server defaults to '*' when NODE_ENV != production.
# APP_ORIGIN=https://your-app.example.com

# WebRTC ICE servers (served to authenticated clients via GET /api/ice-servers).
# STUN_URL defaults to the public Google STUN server if unset. TURN is optional — omit it if
# you have no relay. Consider coturn (https://github.com/coturn/coturn) for a self-hosted one.
# STUN_URL=stun:stun.l.google.com:19302
# TURN_URL=turn:your-turn-server.example.com:3478
#
# TURN auth — two modes:
#   1. Ephemeral (preferred). Set TURN_STATIC_AUTH_SECRET to the same value as coturn's
#      `static-auth-secret` (with `use-auth-secret` enabled). The server then mints short-lived
#      credentials per request, so a leaked credential expires on its own. TURN_TTL_SECONDS is
#      the credential lifetime (default 3600).
# TURN_STATIC_AUTH_SECRET=your-coturn-shared-secret
# TURN_TTL_SECONDS=3600
#   2. Static fallback (used only if TURN_STATIC_AUTH_SECRET is unset). Long-lived credentials —
#      simpler, but they can't be rotated without redeploying coturn.
# TURN_USERNAME=your-turn-username
# TURN_CREDENTIAL=your-turn-credential
