# aframe-gif-shader@0.9.1 declares a stale peer range (aframe@^0.9.0) that predates
# A-Frame's 1.x renumbering. The shader still registers/works on A-Frame 1.7, so we
# relax peer resolution rather than pin A-Frame back.
legacy-peer-deps=true

# Match CI (Node 24) and package.json engines. Fail install on older Node instead of
# shipping a broken runtime (process.loadEnvFile, util.styleText, …) — issue #144.
engine-strict=true
