{
  "name": "transcend",
  "version": "1.0.0",
  "description": "A social and educational VR environment.",
  "main": "server/index.ts",
  "type": "module",
  "scripts": {
    "build": "node build.ts",
    "build-watch": "node build.ts --watch",
    "build-prod": "cross-env NODE_ENV=production node build.ts",
    "seed": "node db/seed.ts",
    "migrate": "node db/migrate-cli.ts up",
    "migrate:undo": "node db/migrate-cli.ts down",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "server": "node --watch server/index.ts",
    "start": "node build.ts && node --watch server/index.ts",
    "test": "vitest run",
    "test-watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TranscendVR/transcend.git"
  },
  "keywords": [
    "social",
    "vr"
  ],
  "author": "Joey Darbyshire, Sean McBride, Yoo-Nah Park, Beth Qiang",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/TranscendVR/transcend/issues"
  },
  "homepage": "https://github.com/TranscendVR/transcend#readme",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "aframe": "^1.8.0",
    "aframe-gif-shader": "0.9.1",
    "bcryptjs": "^3.0.0",
    "connect-pg-simple": "^10.0.0",
    "cross-env": "^10.1.0",
    "express": "^5.0.0",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-router": "^7.18.1",
    "redux": "^5.0.1",
    "redux-thunk": "^3.1.0",
    "sequelize": "^6.0.0",
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.7.0",
    "umzug": "^3.8.3"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.1",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react": "^7.0.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "morgan": "^1.11.0",
    "neostandard": "github:neostandard/neostandard#5015236c3a2278969cc72b2f417c5f09ee861284",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
